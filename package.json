{
  "name": "marathon",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "postinstall": "npm run prisma:generate",
    "build:frontend": "cd frontend && npm ci && npm run build",
    "dev:frontend": "cd frontend && npm run dev",
    "audit:legacy-catalog": "node scripts/audit-legacy-marathon-catalog.js",
    "draft:legacy-catalog": "node scripts/draft-legacy-marathon-catalog.js",
    "review:catalog-draft": "node scripts/review-marathon-catalog-draft.js",
    "load:catalog": "node scripts/load-marathon-catalog.js",
    "load:catalog:pod": "sh scripts/load-catalog-in-pod.sh",
    "check:readiness": "node scripts/check-marathon-readiness.js",
    "check:journey": "node scripts/check-marathon-journey.js",
    "check:user-flows": "node scripts/check-marathon-user-flows.js",
    "audit:data-hygiene": "node scripts/check-marathon-data-hygiene.js",
    "check:production-smoke": "node scripts/run-production-smoke-safe.js",
    "smoke:production-safe": "node scripts/run-production-smoke-safe.js",
    "check:admin-pricing": "python3 scripts/check-marathon-admin-pricing-contract.py",
    "backfill:auth-users:dry-run": "node scripts/backfill-marathon-auth-users.js",
    "backfill:auth-users:apply": "node scripts/backfill-marathon-auth-users.js --apply",
    "check:assignment-contract": "node scripts/check-assignment-contract.js"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.10",
    "@nestjs/core": "^10.3.10",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/serve-static": "^4.0.2",
    "@prisma/client": "^5.11.0",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "stream-json": "^1.7.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.30",
    "prisma": "^5.11.0",
    "typescript": "^5.4.5"
  }
}
