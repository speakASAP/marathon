# ============================================
# Application Configuration. Single Source of Truth
# ============================================
NODE_ENV=
DOMAIN=
SERVICE_NAME=

# ============================================
# External Shared Microservices
# ============================================
AUTH_SERVICE_URL=
NOTIFICATION_SERVICE_URL=
AI_SERVICE_URL=
AI_SERVICE_TOKEN=
AI_SERVICE_JWT_SECRET=
SUPPORT_CHAT_MODEL_TIER=
SUPPORT_CHAT_AI_TIMEOUT_MS=
# Primary logging URL. Keep logical host by default; color-specific hostnames are handled by fallback logic in code.
LOGGING_SERVICE_URL=
LOGGING_SERVICE_API_PATH=
# Optional comma-separated fallback base URLs for blue/green color switches.
LOGGING_SERVICE_URL_FALLBACKS=

# Portal-issued JWT for session users (Phase B). Same secret as speakasap-portal MARATHON_PORTAL_JWT_SECRET.
MARATHON_PORTAL_JWT_SECRET=

# ============================================
# Database Server (Shared PostgreSQL)
# ============================================
DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DATABASE_URL=

# ============================================
# Prisma Engine Configuration
# ============================================
PRISMA_SCHEMA_ENGINE_BINARY=
PRISMA_QUERY_ENGINE_BINARY=

# ============================================
# Redis Cache (Shared Redis) - Optional
# ============================================
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DB=

# ============================================
# Service Ports
# ============================================
PORT=
PORT_GREEN=

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=
LOG_TIMESTAMP_FORMAT=

# ============================================
# Notification Configuration
# ============================================
NOTIFICATION_ORDER_CREATED=
NOTIFICATION_ORDER_UPDATED=
NOTIFICATION_STOCK_LOW=
NOTIFICATION_SYNC_ERROR=
NOTIFICATION_EMAIL_TO=

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN=

# ============================================
# Network Configuration
# ============================================
NGINX_NETWORK_NAME=

# ============================================
# HTTP Timeout Configuration
# ============================================
HTTP_TIMEOUT=
GATEWAY_TIMEOUT=
AUTH_SERVICE_TIMEOUT=
NOTIFICATION_SERVICE_TIMEOUT=
LOGGING_SERVICE_TIMEOUT=

# ============================================
# Retry Configuration
# ============================================
RETRY_MAX_ATTEMPTS=
RETRY_DELAY_MS=
AUTH_RETRY_MAX_ATTEMPTS=
AUTH_RETRY_DELAY_MS=
NOTIFICATION_RETRY_MAX_ATTEMPTS=
NOTIFICATION_RETRY_DELAY_MS=

# Frontend URL (optional, CORS_ORIGIN can be used instead)
FRONTEND_URL=

# Frontend auth redirect (optional). Central Auth returns access_token in the fragment.
# Legacy VITE_PORTAL_LOGIN_URL remains supported as a fallback and uses next=.
VITE_AUTH_LOGIN_URL=https://auth.alfares.cz/login
VITE_AUTH_REGISTER_URL=https://auth.alfares.cz/register
VITE_AUTH_CLIENT_ID=marathon
VITE_AUTH_PASSWORD_RESET_URL=
VITE_PORTAL_LOGIN_URL=
VITE_PORTAL_PASSWORD_RESET_URL=

# Unified payments configuration
PAYMENT_APPLICATION_ID=
PAYMENT_SERVICE_URL=
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_API_KEY=
PAYMENT_CALLBACK_URL=
PAYMENT_SUCCESS_URL=
PAYMENT_CANCEL_URL=

JWT_TOKEN=

# Comma-separated Auth user IDs or emails allowed to use /admin/marathons/prices.
MARATHON_ADMIN_USER_IDS=
MARATHON_ADMIN_EMAILS=
