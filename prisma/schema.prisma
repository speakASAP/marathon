generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Marathon {
  id              String              @id @default(uuid())
  languageCode    String
  title           String
  slug            String              @unique
  rulesTemplate   String?
  active          Boolean             @default(false)
  landingVideoUrl String?
  discountEndsAt  DateTime?
  coverImageUrl   String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  steps           MarathonStep[]
  participants    MarathonParticipant[]
  gifts           MarathonGift[]
  product         MarathonProduct?
}

model MarathonStep {
  id                String   @id @default(uuid())
  marathonId        String
  title             String
  assignmentContent String?
  assignmentBlocks  Json?
  sequence          Int
  isPenalized       Boolean  @default(true)
  formKey           String?
  socialLink        String?
  isTrialStep       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  marathon          Marathon @relation(fields: [marathonId], references: [id])
  submissions       StepSubmission[]

  @@unique([marathonId, sequence])
}

model MarathonParticipant {
  id               String   @id @default(uuid())
  userId           String?
  marathonId       String
  email            String?
  phone            String?
  name             String?
  paid             Boolean  @default(false)
  bonusDaysLeft    Int      @default(0)
  canUsePenalty    Boolean  @default(true)
  active           Boolean  @default(true)
  reportHour       DateTime
  hasWarning       Boolean  @default(false)
  createdAt        DateTime @default(now())
  finishedAt       DateTime?
  certificateName  String?
  certificateNameConfirmedAt DateTime?
  marathon         Marathon @relation(fields: [marathonId], references: [id])
  submissions      StepSubmission[]
  penaltyReports   PenaltyReport[]
  paymentAttempts  MarathonPaymentAttempt[]
  surveyResponse    MarathonSurveyResponse?
}

model StepSubmission {
  id           String             @id @default(uuid())
  participantId String
  stepId       String
  startAt      DateTime
  endAt        DateTime
  isCompleted  Boolean            @default(false)
  isChecked    Boolean            @default(false)
  rating       Int                @default(0)
  payloadJson  Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  participant  MarathonParticipant @relation(fields: [participantId], references: [id])
  step         MarathonStep       @relation(fields: [stepId], references: [id])
}

model PenaltyReport {
  id            String             @id @default(uuid())
  participantId String
  completed     Boolean            @default(false)
  completeTime  DateTime?
  value         Json?
  createdAt     DateTime           @default(now())
  participant   MarathonParticipant @relation(fields: [participantId], references: [id])
}

model MarathonWinner {
  id          String   @id @default(uuid())
  userId      String
  goldCount   Int      @default(0)
  silverCount Int      @default(0)
  bronzeCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([goldCount(sort: Desc), silverCount(sort: Desc), bronzeCount(sort: Desc)])
}

model MarathonUserProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  displayName  String?
  avatarUrl    String?
  bio          String?
  avatarSource String   @default("generated")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([avatarSource])
}

model MarathonGift {
  id               String   @id @default(uuid())
  marathonId       String
  code             String   @unique
  createdAt        DateTime @default(now())
  usedAt           DateTime?
  redeemedByUserId String?
  marathon         Marathon @relation(fields: [marathonId], references: [id])
}

model MarathonProduct {
  id          String   @id @default(uuid())
  marathonId  String   @unique
  title       String
  price       Decimal
  currency    String
  totalHours  Int      @default(50)
  marathon    Marathon @relation(fields: [marathonId], references: [id])
  paymentAttempts MarathonPaymentAttempt[]
}

model MarathonPaymentAttempt {
  id                String              @id @default(uuid())
  orderId           String              @unique
  participantId     String
  productId         String
  amount            Decimal
  currency          String
  paymentMethod     String
  status            String              @default("checkout_requested")
  providerPaymentId String?
  checkoutResponse  Json?
  callbackPayload   Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  confirmedAt       DateTime?
  participant       MarathonParticipant @relation(fields: [participantId], references: [id])
  product           MarathonProduct     @relation(fields: [productId], references: [id])

  @@index([participantId])
  @@index([status])
}

model MarathonSurveyResponse {
  id            String              @id @default(uuid())
  participantId String              @unique
  score         Int
  comment       String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  participant   MarathonParticipant @relation(fields: [participantId], references: [id])

  @@index([score])
}
